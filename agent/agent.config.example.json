{
  "serverUri": "https://lppsp.ui.ac.id/any/server",
  "enrollmentCode": "change-me-locally",
  "deviceName": "My PHP snapshot agent",
  "pollIntervalMs": 800,
  "initialTransportMode": "poll",
  "longPollMs": 15000,
  "requestTimeoutMs": 30000,
  "heartbeatLogMs": 30000,
  "configReloadMs": 2000,
  "reconnectMinMs": 250,
  "reconnectMaxMs": 10000,
  "logDirectory": "./logs",
  "fileTransferRoot": "./transfer",
  "maxUploadBytes": 10485760,
  "maxTransferBytes": 10485760,
  "allowScreenCapture": true,
  "allowRemoteControl": true,
  "allowKeyboardInput": true,
  "allowClipboardPaste": true,
  "allowFileTransfer": true,
  "allowSessionRecording": true,
  "allowPowerControl": false,
  "allowWebRtcTransport": true,
  "webRtcSignalPollMs": 1000,
  "webRtcFrameFps": 10,
  "webRtcFrameChunkBytes": 65536,
  "webRtcIceServers": [
    { "urls": "stun:stun.l.google.com:19302" }
  ],
  "preventSleepWhileRunning": false,
  "maxClipboardTextBytes": 8192,
  "wheelScrollMultiplier": 16
